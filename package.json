{
  "name": "magnetar-quill",
  "version": "0.10.2",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "build-lib": "ng build lib-magnetar-quill",
    "build-lib-watch": "ng build lib-magnetar-quill --watch --configuration development",
    "serve-with-lib": ". ~/.nvm/nvm.sh && nvm use && npm run build-lib && ng serve --port 4200",
    "serve-with-lib-linux": "bash -lc 'npm run build-lib-watch & build_pid=$!; npm run start -- --port 4200 & start_pid=$!; trap \"kill $build_pid $start_pid 2>/dev/null\" EXIT; wait -n $build_pid $start_pid'",
    "test": "ng test --watch=false --code-coverage",
    "test-ci": "ng test --watch=false --no-progress --browsers=ChromeHeadlessCI --code-coverage",
    "test-lib-magnetar-quill": "ng test lib-magnetar-quill --watch=false --code-coverage",
    "lint": "npm run lint:info-docs && npm run lint:styles && ng lint",
    "lint:info-docs": "node scripts/info-docs.mjs --check",
    "lint:styles": "node scripts/style-lint.mjs",
    "docs:generate:info-docs": "node scripts/info-docs.mjs --write",
    "validate": "bash scripts/validate.sh"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@angular/router": "^22.0.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.3.0",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/core": "^22.0.0",
    "@angular-devkit/schematics": "^22.0.0",
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/js": "^10.0.1",
    "@schematics/angular": "^22.0.0",
    "@types/jasmine": "~5.1.0",
    "angular-eslint": "^22.0.0",
    "eslint": "^10.0.3",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^22.0.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.61.0"
  }
}
